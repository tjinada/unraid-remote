# ─── App (single-user auth) ───────────────────────────────
APP_USER=admin
APP_PASS=change-me
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Local state (plain JSON) ─────────────────────────────
DATA_DIR=./data

# ─── SSH target (used from Phase 2) ───────────────────────
# SSH_HOST=192.168.1.10
# SSH_PORT=22
# SSH_USER=root
# SSH_PASS=
# SSH_KEY=            # absolute path to a private key (use instead of SSH_PASS)

# ─── File explorer sandbox ────────────────────────────────
# Comma-separated roots the explorer may access (default shown).
ALLOWED_ROOTS=/mnt/user,/boot

# ─── Push (infra only; used from Phase 5) ─────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com
